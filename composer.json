{
    "name": "dskripchenko/laravel-api",
    "description": "The Laravel Api Module.",
    "license": "MIT",
    "homepage": "https://github.com/dskripchenko/laravel-api",
    "keywords": [
        "laravel",
        "api",
        "versioning",
        "swagger"
    ],
    "authors": [
        {
            "name": "Denis Skripchenko",
            "email": "denskrp90@gmail.com"
        }
    ],
    "require": {
        "ext-json": "*",
        "dskripchenko/php-array-helper": "^1.0",
        "laravel/framework": "6.*|7.*|8.*|9.*|10.*|11.*|12.*",
        "phpdocumentor/reflection-docblock": "*"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "orchestra/testbench": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Dskripchenko\\LaravelApi\\": [
                "src/"
            ],
            "Dskripchenko\\LaravelApiExample\\": [
                "example/"
            ]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
