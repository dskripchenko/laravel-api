{
    "name": "dskripchenko/laravel-api",
    "description": "Versioned Laravel APIs with OpenAPI 3.0 docs auto-generated from PHP docblocks — no annotations, no YAML — plus CRUD scaffolding and middleware cascades.",
    "license": "MIT",
    "homepage": "https://github.com/dskripchenko/laravel-api",
    "keywords": [
        "laravel",
        "api",
        "rest-api",
        "api-versioning",
        "openapi",
        "swagger",
        "documentation",
        "crud",
        "scaffolding",
        "typescript"
    ],
    "authors": [
        {
            "name": "Denis Skripchenko",
            "email": "denskrp90@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "dskripchenko/php-array-helper": "^1.0",
        "laravel/framework": "^11.0 || ^12.0 || ^13.0",
        "phpdocumentor/reflection-docblock": "^6.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "orchestra/testbench": "^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Dskripchenko\\LaravelApi\\": [
                "src/"
            ],
            "Dskripchenko\\LaravelApiExample\\": [
                "example/"
            ]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
